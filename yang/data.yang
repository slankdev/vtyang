module slankdev {
  namespace "http://slank.dev/vtyang"
  prefix slankdev;

  container segment-routing {
    container srv6 {
      container locators {
        container locators {
          list locator {
            key "name";
            leaf prefix { type string; }
            leaf name { type string; }
          }
        }
      }
    }
  }

  container segment-routing-state {
    config false;
    leaf running {
      type boolean;
      default false;
    }
  }

